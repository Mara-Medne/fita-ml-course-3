    "question": "Jautājums 3: Vidējais maksājuma apjoms pa gadiem",
    "sql": "SELECT YEAR(p.created_at) AS payment_year, AVG(p.amount) AS avg_payment\nFROM payments p\nGROUP BY YEAR(p.created_at)\nORDER BY payment_year",
